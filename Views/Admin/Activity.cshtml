@model HRSystem.Models.AdminActivityViewModel

@{
    ViewData["Title"] = "Live Changes";
    var rows = Model.ChangeLogs.Items;
    var workbookRows = Model.LatestWorkbookEntries.Items;
    var importedAtText = Model.LatestImportedAtUtc.HasValue
        ? Model.LatestImportedAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
        : "—";
}

<div class="admin-page-shell" data-live-change-feed="true" data-hub-url="@Url.Content("~/hubs/changelog")">
    <section class="admin-panel-card mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
            <div>
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                    <span class="badge rounded-pill bg-primary px-3 py-2">Admin Only</span>
                    <span class="badge rounded-pill text-bg-light text-dark border px-3 py-2">Live audit</span>
                </div>
                <h1 class="h3 fw-bold mb-2">Live changes table</h1>
                <p class="text-muted mb-0">
                    This table shows the latest changes across the system: imports, edits, deletes, approvals, and role updates.
                    It updates in real time while the page is open and refreshes every 15 seconds as a backup.
                </p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-outline-secondary" asp-controller="Dashboard" asp-action="Index">Back to home</a>
                <a class="btn btn-primary" asp-action="Users">Manage users</a>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-card__label">Changes visible</div>
                    <div class="stat-card__value" id="change-log-count">@Model.ChangeLogs.Pagination.TotalCount</div>
                    <div class="stat-card__hint">Latest audit entries</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-card__label">Newest item</div>
                    <div class="stat-card__value" style="font-size:1.05rem;" id="change-log-newest">@(rows.FirstOrDefault()?.Action ?? "None")</div>
                    <div class="stat-card__hint">Top of the feed</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-card__label">Connection</div>
                    <div class="stat-card__value" id="change-log-connection">Connecting</div>
                    <div class="stat-card__hint">SignalR feed</div>
                </div>
            </div>
        </div>

        @if (rows.Count == 0)
        {
            <div class="empty-state" id="change-log-empty">
                <h3 class="h5 fw-bold mb-2">No changes yet</h3>
                <p class="text-muted mb-0">Once users start importing, editing, approving, or deleting records, the live table will fill here.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle admin-table mb-0">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Actor</th>
                            <th>Entity</th>
                            <th>Action</th>
                            <th>Summary</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody id="change-log-body">
                        @foreach (var row in rows)
                        {
                            <tr data-log-id="@row.Id">
                                <td class="text-nowrap">@row.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@row.ActorName</td>
                                <td>
                                    <span class="badge rounded-pill text-bg-light text-dark border">@row.EntityType</span>
                                </td>
                                <td>
                                    <span class="badge rounded-pill text-bg-primary">@row.Action</span>
                                </td>
                                <td>@row.Summary</td>
                                <td class="text-muted small">@(string.IsNullOrWhiteSpace(row.Details) ? "—" : row.Details)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @await Html.PartialAsync("_Pagination", Model.ChangeLogs.Pagination)
        }
    </section>

    <section class="admin-panel-card mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
            <div>
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                    <span class="badge rounded-pill bg-success px-3 py-2">Workbook table</span>
                    <span class="badge rounded-pill text-bg-light text-dark border px-3 py-2">Latest import</span>
                </div>
                <h2 class="h4 fw-bold mb-2">Full Excel sheet rows</h2>
                <p class="text-muted mb-0">
                    This is the most recent imported rotation sheet saved in the database. It refreshes every 15 seconds so you can keep watching the rows change.
                </p>
            </div>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-outline-secondary" asp-action="ImportEmployees">Import another workbook</a>
                    <a class="btn btn-outline-primary" asp-controller="Rotations" asp-action="Index">Open rotations</a>
                    @if (Model.LatestRotationId.HasValue)
                    {
                        <a class="btn btn-success" asp-controller="Rotations" asp-action="DownloadWorkbook" asp-route-id="@Model.LatestRotationId.Value">Download workbook</a>
                    }
                </div>
            </div>

        @if (string.IsNullOrWhiteSpace(Model.LatestWorkbookTitle))
        {
            <div class="empty-state">
                <h3 class="h5 fw-bold mb-2">No workbook imported yet</h3>
                <p class="text-muted mb-0">Upload the Excel sheet first, then this table will show the saved schedule rows here.</p>
            </div>
        }
        else if (workbookRows.Count == 0)
        {
            <div class="empty-state">
                <h3 class="h5 fw-bold mb-2">No rows for today</h3>
                <p class="text-muted mb-0">
                    The latest workbook is imported, but there are no schedule rows with today’s date yet.
                </p>
            </div>
        }
        else
        {
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="stat-card__label">Rotation title</div>
                        <div class="stat-card__value" style="font-size:1.05rem;">@Model.LatestWorkbookTitle</div>
                        <div class="stat-card__hint">Latest imported workbook</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="stat-card__label">Sheet name</div>
                        <div class="stat-card__value" style="font-size:1.05rem;">@(string.IsNullOrWhiteSpace(Model.LatestSheetName) ? "—" : Model.LatestSheetName)</div>
                        <div class="stat-card__hint">Source Excel worksheet</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="stat-card__label">Imported at</div>
                        <div class="stat-card__value">@importedAtText</div>
                        <div class="stat-card__hint">Workbook upload timestamp</div>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table align-middle admin-table mb-0">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Arabic name</th>
                            <th>Job title</th>
                            <th>Work date</th>
                            <th>Original status</th>
                            <th>Current status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in workbookRows)
                        {
                            <tr>
                                <td class="text-nowrap">@row.EmployeeCode</td>
                                <td>@row.EmployeeName</td>
                                <td>@row.JobTitle</td>
                                <td class="text-nowrap">@row.WorkDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <span class="badge rounded-pill text-bg-light text-dark border">@row.OriginalStatus</span>
                                </td>
                                <td>
                                    <span class="badge rounded-pill @((string.Equals(row.Status, "إجازة", StringComparison.OrdinalIgnoreCase) || string.Equals(row.Status, "On Leave", StringComparison.OrdinalIgnoreCase)) ? "text-bg-warning text-dark" : "text-bg-success")">@row.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @await Html.PartialAsync("_Pagination", Model.LatestWorkbookEntries.Pagination)
        }
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js" crossorigin="anonymous"></script>
    <script>
        (function () {
            const root = document.querySelector('[data-live-change-feed="true"]');
            if (!root || typeof signalR === 'undefined') {
                return;
            }

            const hubUrl = root.getAttribute('data-hub-url');
            const body = document.getElementById('change-log-body');
            const countEl = document.getElementById('change-log-count');
            const newestEl = document.getElementById('change-log-newest');
            const connectionEl = document.getElementById('change-log-connection');
            const emptyState = document.getElementById('change-log-empty');
            const maxRows = 100;

            const setConnection = (text, isConnected) => {
                if (!connectionEl) return;
                connectionEl.textContent = text;
                connectionEl.classList.toggle('text-success', !!isConnected);
                connectionEl.classList.toggle('text-warning', !isConnected);
            };

            const escapeHtml = (value) => String(value ?? '')
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#39;');

            const formatTime = (value) => {
                const date = new Date(value);
                return Number.isNaN(date.getTime()) ? '' : date.toLocaleString();
            };

            const appendRow = (entry) => {
                if (!body || !entry) return;

                if (emptyState) {
                    emptyState.remove();
                }

                const row = document.createElement('tr');
                row.dataset.logId = entry.id ?? '';
                row.innerHTML = `
                    <td class="text-nowrap">${escapeHtml(formatTime(entry.createdAtUtc))}</td>
                    <td>${escapeHtml(entry.actorName)}</td>
                    <td><span class="badge rounded-pill text-bg-light text-dark border">${escapeHtml(entry.entityType)}</span></td>
                    <td><span class="badge rounded-pill text-bg-primary">${escapeHtml(entry.action)}</span></td>
                    <td>${escapeHtml(entry.summary)}</td>
                    <td class="text-muted small">${entry.details ? escapeHtml(entry.details) : '—'}</td>
                `;

                body.prepend(row);

                while (body.children.length > maxRows) {
                    body.lastElementChild?.remove();
                }

                if (countEl) {
                    const current = parseInt(countEl.textContent || '0', 10);
                    countEl.textContent = String(Math.min(maxRows, isNaN(current) ? body.children.length : current + 1));
                }

                if (newestEl) {
                    newestEl.textContent = entry.action ?? 'Change';
                }
            };

            const connection = new signalR.HubConnectionBuilder()
                .withUrl(hubUrl)
                .withAutomaticReconnect()
                .build();

            connection.on('ChangeLogged', appendRow);
            connection.onreconnecting(() => setConnection('Reconnecting', false));
            connection.onreconnected(() => setConnection('Live', true));
            connection.onclose(() => setConnection('Disconnected', false));

            connection.start()
                .then(() => setConnection('Live', true))
                .catch(() => setConnection('Offline', false));

            window.setInterval(() => {
                window.location.reload();
            }, 15000);
        })();
    </script>
}
