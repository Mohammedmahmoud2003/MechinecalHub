@{
    ViewData["Title"] = "System Settings";
}

<div class="admin-page-shell">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">System settings</h1>
            <p class="text-muted mb-0">Central place for future app-wide configuration.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-controller="Dashboard" asp-action="Index">Back to home</a>
    </div>

    <div class="admin-panel-card">
        <p class="mb-0 text-muted">
            This page is ready for settings like password policy, default role rules, feature toggles, and notification preferences.
        </p>
    </div>
</div>
