@model Rotation
@{
    ViewData["Title"] = "Edit rotation";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="mb-4">
            <h1 class="h2 mb-1">Edit rotation</h1>
            <p class="text-muted mb-0">Update the title, timing, and status for this rotation.</p>
        </div>

        <div class="task-detail-card">
            <form asp-action="Edit" method="post" enctype="multipart/form-data" class="row g-3">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <input type="hidden" asp-for="Id" />

                <div class="col-12">
                    <label class="form-label">Excel workbook</label>
                    <input class="form-control" type="file" name="workbook" accept=".xlsx" />
                    <div class="form-text">Upload a new workbook to replace the current rotation sheet.</div>
                    @if (!string.IsNullOrWhiteSpace(Model.SourceWorkbookTitle))
                    {
                        <div class="small text-muted mt-2">
                            Current workbook: @Model.SourceWorkbookTitle
                            @if (!string.IsNullOrWhiteSpace(Model.SourceSheetName))
                            {
                                <span>(sheet: @Model.SourceSheetName)</span>
                            }
                        </div>
                    }
                </div>

                <div class="col-12">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger small d-block"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger small d-block"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="StartAt" class="form-label"></label>
                    <input asp-for="StartAt" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" class="form-control" />
                    <span asp-validation-for="StartAt" class="text-danger small d-block"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="EndAt" class="form-label"></label>
                    <input asp-for="EndAt" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" class="form-control" />
                    <span asp-validation-for="EndAt" class="text-danger small d-block"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<RotationStatus>()"></select>
                    <span asp-validation-for="Status" class="text-danger small d-block"></span>
                </div>

                <div class="col-12 d-flex flex-wrap gap-2 pt-2">
                    <button type="submit" class="btn btn-primary px-4">Save</button>
                    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
