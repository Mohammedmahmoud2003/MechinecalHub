@model Rotation
@{
    ViewData["Title"] = "Rotation details";
    var ownerNames = ViewBag.OwnerNamesById as IDictionary<string, string> ?? new Dictionary<string, string>();
    var importedSchedulePage = ViewBag.ImportedSchedulePage as PagedResultViewModel<RotationScheduleSummaryViewModel> ?? new PagedResultViewModel<RotationScheduleSummaryViewModel>();
    var ownerName = !string.IsNullOrWhiteSpace(Model.OwnerUserId) && ownerNames.TryGetValue(Model.OwnerUserId, out var displayName)
        ? displayName
        : Model.OwnerUserId;
}

<div class="task-detail-shell">
    <section class="task-detail-hero mb-4">
        <div>
            <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                <span class="badge rounded-pill text-bg-light text-dark px-3 py-2">Rotation Details</span>
                <span class="badge rounded-pill bg-primary px-3 py-2">@Model.Status</span>
            </div>
            <h1 class="h2 fw-bold mb-2">@Model.Title</h1>
            <p class="text-white-50 mb-0">@((string.IsNullOrWhiteSpace(Model.Description) ? "No description provided." : Model.Description))</p>
        </div>

        <div class="task-detail-hero__meta">
            <div>
                <span class="task-detail-hero__label">Start</span>
                <strong>@Model.StartAt.ToString("g")</strong>
            </div>
            <div>
                <span class="task-detail-hero__label">End</span>
                <strong>@Model.EndAt.ToString("g")</strong>
            </div>
        </div>
    </section>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="task-detail-card">
                <h2 class="h5 fw-bold mb-3">Rotation information</h2>
                <dl class="row mb-0 task-detail-dl">
                    <dt class="col-sm-4">Title</dt>
                    <dd class="col-sm-8">@Model.Title</dd>

                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8"><span class="badge bg-secondary rounded-pill">@Model.Status</span></dd>

                    <dt class="col-sm-4">Owner</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(ownerName) ? "—" : ownerName)</dd>

                    <dt class="col-sm-4">Created (UTC)</dt>
                    <dd class="col-sm-8">@Model.CreatedAtUtc.ToString("g")</dd>

                    @if (!string.IsNullOrWhiteSpace(Model.SourceSheetName))
                    {
                        <dt class="col-sm-4">Source sheet</dt>
                        <dd class="col-sm-8">@Model.SourceSheetName</dd>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.SourceWorkbookTitle))
                    {
                        <dt class="col-sm-4">Source workbook</dt>
                        <dd class="col-sm-8">@Model.SourceWorkbookTitle</dd>
                    }

                    <dt class="col-sm-4">Imported at</dt>
                    <dd class="col-sm-8">@Model.ImportedAtUtc.ToLocalTime().ToString("g")</dd>
                </dl>

                @if (Model.TaskItems.Count > 0)
                {
                    <h3 class="h6 fw-bold mt-4 mb-3">Linked tasks</h3>
                    <div class="list-group">
                        @foreach (var t in Model.TaskItems.OrderBy(x => x.Title))
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span>@t.Title</span>
                                <span class="badge bg-secondary rounded-pill">@t.Status</span>
                            </div>
                        }
                    </div>
                }

                @if (importedSchedulePage.Items.Count > 0)
                {
                    <h3 class="h6 fw-bold mt-4 mb-3">Imported schedule</h3>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Employee</th>
                                    <th>Job title</th>
                                    <th>Days</th>
                                    <th>Range</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in importedSchedulePage.Items)
                                {
                                    <tr>
                                        <td>@row.EmployeeCode</td>
                                        <td>@row.EmployeeName</td>
                                        <td>@row.JobTitle</td>
                                        <td>@row.Days</td>
                                        <td>@row.StartDate.ToString("yyyy-MM-dd") to @row.EndDate.ToString("yyyy-MM-dd")</td>
                                        <td>
                                            @if (row.LeaveCount == 0)
                                            {
                                                <span class="badge bg-success rounded-pill">Working</span>
                                            }
                                            else if (row.WorkingCount == 0)
                                            {
                                                <span class="badge bg-warning text-dark rounded-pill">On leave</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info text-dark rounded-pill">Mixed</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @await Html.PartialAsync("_Pagination", importedSchedulePage.Pagination)
                }
            </div>
        </div>

        <div class="col-lg-4">
            <div class="task-detail-card h-100">
                <h2 class="h5 fw-bold mb-3">Actions</h2>
                <div class="d-grid gap-2">
                    <a class="btn btn-outline-secondary" asp-action="Index">Back to list</a>
                    <a class="btn btn-outline-success" asp-action="DownloadWorkbook" asp-route-id="@Model.Id">Download workbook</a>
                    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
                    @if (Model.Status == RotationStatus.Planned)
                    {
                        <form asp-action="Approve" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-success w-100">Approve</button>
                        </form>
                    }
                    @if (Model.Status is RotationStatus.Planned or RotationStatus.Active)
                    {
                        <form asp-action="Reject" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-warning w-100">Reject</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
