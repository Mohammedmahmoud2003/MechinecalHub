@model Rotation
@{
    ViewData["Title"] = "Delete rotation";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="task-delete-card">
            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-danger rounded-pill px-3 py-2">Delete rotation</span>
                <span class="text-muted">Linked tasks will be unlinked.</span>
            </div>

            <h1 class="h3 fw-bold mb-2">Are you sure you want to delete this rotation?</h1>
            <p class="text-muted mb-4">Review the record before removing it from the system.</p>

            <dl class="row task-detail-dl mb-4">
                <dt class="col-sm-4">Title</dt>
                <dd class="col-sm-8">@Model.Title</dd>

                <dt class="col-sm-4">Status</dt>
                <dd class="col-sm-8"><span class="badge bg-secondary rounded-pill">@Model.Status</span></dd>
            </dl>

            <form asp-action="Delete" class="d-flex flex-wrap gap-2">
                <input type="hidden" asp-for="Id" />
                <input type="submit" value="Delete rotation" class="btn btn-danger" />
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            </form>
        </div>
    </div>
</div>
