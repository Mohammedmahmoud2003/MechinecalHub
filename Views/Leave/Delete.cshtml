@model LeaveRequest
@{
    ViewData["Title"] = "Delete leave request";
}

<h1>Delete leave request</h1>

<h3 class="text-danger">Are you sure you want to delete this request?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Dates</dt>
        <dd class="col-sm-10">@Model.StartDate — @Model.EndDate</dd>
        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </form>
</div>
