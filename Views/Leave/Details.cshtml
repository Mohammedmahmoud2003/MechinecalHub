@using HRSystem.Infrastructure
@model LeaveRequest
@{
    ViewData["Title"] = "Leave details";
    var uid = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var canReviewRole = User.IsInRole(AppRoles.Manager) || User.IsInRole(AppRoles.Admin);
    var usersById = ViewBag.UserNamesById as IDictionary<string, string> ?? new Dictionary<string, string>();
    var canReview = canReviewRole
        && Model.Status == LeaveRequestStatus.Pending
        && !string.Equals(Model.EmployeeUserId, uid, StringComparison.Ordinal);
    var employeeName = !string.IsNullOrWhiteSpace(Model.EmployeeUserId) && usersById.TryGetValue(Model.EmployeeUserId, out var employeeDisplay)
        ? employeeDisplay
        : Model.EmployeeUserId;
    var reviewerName = !string.IsNullOrWhiteSpace(Model.ReviewerUserId) && usersById.TryGetValue(Model.ReviewerUserId, out var reviewerDisplay)
        ? reviewerDisplay
        : Model.ReviewerUserId;
}

<div class="task-detail-shell">
    <section class="task-detail-hero mb-4">
        <div>
            <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                <span class="badge rounded-pill text-bg-light text-dark px-3 py-2">Leave Details</span>
                <span class="badge rounded-pill bg-primary px-3 py-2">@Model.Status</span>
            </div>
            <h1 class="h2 fw-bold mb-2">@Model.StartDate to @Model.EndDate</h1>
            <p class="text-white-50 mb-0">
                @(string.IsNullOrWhiteSpace(Model.Reason) ? "No reason provided." : Model.Reason)
            </p>
        </div>

        <div class="task-detail-hero__meta">
            <div>
                <span class="task-detail-hero__label">Employee</span>
                <strong>@employeeName</strong>
            </div>
            <div>
                <span class="task-detail-hero__label">Duration</span>
                <strong>@(Model.EndDate.DayNumber - Model.StartDate.DayNumber + 1) day(s)</strong>
            </div>
        </div>
    </section>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="task-detail-card">
                <h2 class="h5 fw-bold mb-3">Request information</h2>
                <dl class="row mb-0 task-detail-dl">
                    <dt class="col-sm-4">Employee</dt>
                    <dd class="col-sm-8">@employeeName</dd>

                    <dt class="col-sm-4">Start date</dt>
                    <dd class="col-sm-8">@Model.StartDate</dd>

                    <dt class="col-sm-4">End date</dt>
                    <dd class="col-sm-8">@Model.EndDate</dd>

                    <dt class="col-sm-4">Reason</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Reason) ? "—" : Model.Reason)</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8"><span class="badge bg-secondary rounded-pill">@Model.Status</span></dd>

                    <dt class="col-sm-4">Submitted (UTC)</dt>
                    <dd class="col-sm-8">@Model.SubmittedAtUtc.ToString("g")</dd>

                    <dt class="col-sm-4">Reviewed (UTC)</dt>
                    <dd class="col-sm-8">@(Model.ReviewedAtUtc?.ToString("g") ?? "—")</dd>

                    <dt class="col-sm-4">Reviewer</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(reviewerName) ? "—" : reviewerName)</dd>
                </dl>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="task-detail-card h-100">
                <h2 class="h5 fw-bold mb-3">Actions</h2>
                <div class="d-grid gap-2">
                    <a class="btn btn-outline-secondary" asp-action="Index">Back to list</a>
                    @if (Model.Status is LeaveRequestStatus.Draft or LeaveRequestStatus.Pending && Model.EmployeeUserId == uid)
                    {
                        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
                        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
                    }
                    @if (canReview)
                    {
                        <form asp-action="Approve" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-success w-100">Approve</button>
                        </form>
                        <form asp-action="Reject" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-warning w-100">Reject</button>
                        </form>
                        <a class="btn btn-outline-secondary" asp-action="Pending">Back to review queue</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
