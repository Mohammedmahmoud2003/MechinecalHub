@model LeaveRequest
@{
    ViewData["Title"] = "New leave request";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="mb-4">
            <h1 class="h2 mb-1">New leave request</h1>
            <p class="text-muted mb-0">Your request is submitted as <strong>Pending</strong> and can be approved by a supervisor or admin.</p>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Create" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label"></label>
                            <input asp-for="StartDate" class="form-control" type="date" />
                            <span asp-validation-for="StartDate" class="text-danger small d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label"></label>
                            <input asp-for="EndDate" class="form-control" type="date" />
                            <span asp-validation-for="EndDate" class="text-danger small d-block"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Reason" class="form-label"></label>
                            <textarea asp-for="Reason" class="form-control" rows="4" placeholder="Optional context for your approver"></textarea>
                            <span asp-validation-for="Reason" class="text-danger small d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4 pt-2 border-top">
                        <button type="submit" class="btn btn-primary px-4">Submit request</button>
                        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
