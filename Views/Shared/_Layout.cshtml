<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MechincalHub</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HRSystem.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var area = ViewContext.RouteData.Values["area"]?.ToString();
        var isIdentityArea = string.Equals(area, "Identity", StringComparison.OrdinalIgnoreCase);
        var showChrome = User.Identity?.IsAuthenticated == true && !isIdentityArea;
    }

    @if (showChrome)
    {
        var controller = ViewContext.RouteData.Values["controller"]?.ToString();
        var dashboardActive = string.Equals(controller, "Dashboard", StringComparison.OrdinalIgnoreCase);
        var leaveActive = string.Equals(controller, "Leave", StringComparison.OrdinalIgnoreCase);
        var tasksActive = string.Equals(controller, "Tasks", StringComparison.OrdinalIgnoreCase);
        var rotationsActive = string.Equals(controller, "Rotations", StringComparison.OrdinalIgnoreCase);
        var canManageTasks = User.IsInRole(HRSystem.Infrastructure.AppRoles.Admin) || User.IsInRole(HRSystem.Infrastructure.AppRoles.Manager);
        var canManageRotations = canManageTasks;

        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container-fluid">
                    <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Dashboard" asp-action="Index">MechincalHub</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link fw-semibold @(dashboardActive ? "nav-link--active" : "text-dark")" asp-area="" asp-controller="Dashboard" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(leaveActive ? "nav-link--active" : "text-dark")" asp-area="" asp-controller="Leave" asp-action="Index">Leave</a>
                            </li>
                            @if (canManageTasks)
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(tasksActive ? "nav-link--active" : "text-dark")" asp-area="" asp-controller="Tasks" asp-action="Index">Tasks</a>
                                </li>
                            }
                            @if (canManageRotations)
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(rotationsActive ? "nav-link--active" : "text-dark")" asp-area="" asp-controller="Rotations" asp-action="Index">Rotations</a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="http://mechanicalhub.somee.com/" target="_blank" rel="noopener">Live Demo</a>
                            </li>
                        </ul>
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </nav>
        </header>
    }
    <div class="container py-4">
        <main role="main" class="pt-5 pb-5 bg-white rounded-4 shadow-sm px-4 px-md-5 mb-5 @(showChrome ? "" : "mt-5")" style="min-height:60vh;">
            @if (TempData["Message"] is string flashOk)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @flashOk
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] is string flashErr)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @flashErr
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    @if (showChrome)
    {
        <footer class="border-top footer text-muted mt-5 pt-4 pb-2 bg-light rounded-top-4 shadow-sm">
            <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                <span>&copy; 2026 - MechincalHub</span>
                <a href="http://mechanicalhub.somee.com/" target="_blank" rel="noopener" class="text-decoration-none">mechanicalhub.somee.com</a>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacy</a>
            </div>
        </footer>
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
