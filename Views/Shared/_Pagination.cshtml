@model PaginationViewModel
@using Microsoft.AspNetCore.Routing

@if (Model.TotalPages > 1)
{
    var current = Model.PageNumber;
    var total = Model.TotalPages;
    var pages = new List<int>();

    if (total <= 7)
    {
        for (var i = 1; i <= total; i++)
        {
            pages.Add(i);
        }
    }
    else
    {
        pages.Add(1);

        var start = Math.Max(2, current - 1);
        var end = Math.Min(total - 1, current + 1);

        if (start > 2)
        {
            pages.Add(-1);
        }

        for (var i = start; i <= end; i++)
        {
            pages.Add(i);
        }

        if (end < total - 1)
        {
            pages.Add(-1);
        }

        pages.Add(total);
    }

    <nav class="mt-4" aria-label="Pagination">
        <ul class="pagination justify-content-center flex-wrap mb-0">
            <li class="page-item @(Model.HasPrevious ? string.Empty : "disabled")">
                <a class="page-link" href="@(Model.HasPrevious ? Url.Action(Model.Action, Model.Controller, Model.BuildRouteValues(Model.PageNumber - 1)) : "#")" aria-label="Previous">
                    Previous
                </a>
            </li>

            @foreach (var pageNumber in pages)
            {
                if (pageNumber == -1)
                {
                    <li class="page-item disabled"><span class="page-link">...</span></li>
                }
                else
                {
                    <li class="page-item @(pageNumber == current ? "active" : string.Empty)">
                        <a class="page-link" href="@Url.Action(Model.Action, Model.Controller, Model.BuildRouteValues(pageNumber))">@pageNumber</a>
                    </li>
                }
            }

            <li class="page-item @(Model.HasNext ? string.Empty : "disabled")">
                <a class="page-link" href="@(Model.HasNext ? Url.Action(Model.Action, Model.Controller, Model.BuildRouteValues(Model.PageNumber + 1)) : "#")" aria-label="Next">
                    Next
                </a>
            </li>
        </ul>
    </nav>
}
